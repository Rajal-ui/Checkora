{
  "version": 2,
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "bash build_files.sh",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python",
      "includeFiles": "{core,game,staticfiles}/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
